-- CMD V2 CORE (SIN UICORNER)
local CMD = {}
CMD.Commands = {}
CMD.Prefix = ";"

-- ========================
-- REGISTRAR COMANDOS
-- ========================
function CMD:AddCommand(data)
    self.Commands[data.Name:lower()] = data
end

-- ========================
-- EJECUTAR TEXTO
-- ========================
function CMD:Execute(text)
    if text:sub(1,1) ~= self.Prefix then return end

    local args = {}
    for word in text:gmatch("%S+") do
        table.insert(args, word)
    end

    local cmdName = args[1]:sub(2):lower()
    table.remove(args, 1)

    local cmd = self.Commands[cmdName]
    if not cmd then return end

    if cmd.HasArgs and #args == 0 then
        warn("Faltan argumentos")
        return
    end

    cmd.Run(unpack(args))
end

-- ========================
-- LISTA DE COMANDOS
-- ========================
CMD:AddCommand({
    Name = "cmds",
    HasArgs = false,
    Desc = "Lista de comandos",
    Run = function()
        print("===== COMANDOS =====")
        for _,cmd in pairs(CMD.Commands) do
            if cmd.HasArgs then
                print(";"..cmd.Name.." ["..cmd.ArgName.."] - "..cmd.Desc)
            else
                print(";"..cmd.Name.." - "..cmd.Desc)
            end
        end
    end
})

