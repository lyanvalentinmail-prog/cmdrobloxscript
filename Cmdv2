local function Refresh(filter)
	Clear()
	for _,cmd in pairs(CMD.Commands) do
		if not filter or cmd.Name:sub(1,#filter):lower() == filter:lower() then
			local argText = cmd.HasArgs and (" ["..cmd.ArgName.."]") or ""
			Line(";"..cmd.Name..argText.." - "..cmd.Desc)
		end
	end
end

-- ================= COMMAND SYSTEM =================
function CMD:AddCommand(data)
	assert(data.Name and data.Run, "Command needs Name and Run")
	CMD.Commands[data.Name:lower()] = data
	Refresh()
end

-- ================= INPUT FILTER =================
Input:GetPropertyChangedSignal("Text"):Connect(function()
	local t = Input.Text
	if t:sub(1,1) ~= ";" then return end

	local clean = string.gsub(t:sub(2), "%s+", " ")
	local name = clean:split(" ")[1]
	Refresh(name)
end)

-- ================= EXECUTE =================
Input.FocusLost:Connect(function(enter)
	if not enter then return end

	local raw = Input.Text
	Input.Text = ""

	if raw:sub(1,1) ~= ";" then return end

	-- limpiar espacios
	raw = string.gsub(raw, "^%s*(.-)%s*$", "%1")
	raw = string.gsub(raw, "%s+", " ")

	local parts = raw:sub(2):split(" ")
	local name = parts[1] and parts[1]:lower()
	table.remove(parts,1)

	local cmd = CMD.Commands[name]
	if not cmd then
		Line("Comando no encontrado", Color3.fromRGB(255,100,100))
		return
	end

	if cmd.HasArgs and not parts[1] then
		Line("Falta argumento: ["..cmd.ArgName.."]", Color3.fromRGB(255,170,0))
		return
	end

	task.spawn(function()
		if cmd.HasArgs then
			cmd.Run(parts[1])
		else
			cmd.Run()
		end
	end)
end)

-- ================= TOGGLE =================
UIS.InputBegan:Connect(function(i,gp)
	if gp then return end
	if i.KeyCode == Enum.KeyCode.RightShift then
		Main.Visible = not Main.Visible
	end
end)

Refresh()
return CMD
